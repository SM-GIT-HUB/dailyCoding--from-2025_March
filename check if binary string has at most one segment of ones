class Solution {
public:
    bool checkOnesSegment(string s) {
        int ones = 0;
        int last = s[0];

        for (char ch : s)
        {
            if ((ch == '1' && last == '0') || (ch == '0' && last == '1')) {
                ++ones;
            }

            last = ch;
        }

        return (ones < 2);
    }
};
