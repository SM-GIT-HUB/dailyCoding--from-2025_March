#include <bits/stdc++.h>

int dirs[4][2] = {{-1, 0}, {0, 1}, {1, 0}, {0, -1}};

int coverageOfMatrix(vector<vector<int> >& mat) {
    // Write your code here.
    int count = 0;

    int m = int(mat.size());
    int n = int(mat[0].size());

    for (int i = 0; i < m; i++)
    {
        for (int j = 0; j < n; j++)
        {
            if (mat[i][j]) continue;

            for (auto &d : dirs)
            {
                int x = i + d[0];
                int y = j + d[1];

                if (x >= 0 && x < m && y >= 0 && y < n && mat[x][y]) {
                    ++count;
                }
            }
        }
    }

    return count;
}
