class Solution {
public:
    long long sumAndMultiply(int n) {
        int sum = 0;
        long long apu = 0;

        unsigned int ten = 1;

        while (n)
        {
            if (n % 10)
            {
                sum += n % 10;
                apu = apu + ten * (n % 10);
                ten = ten * 10;
            }

            n = n / 10;
        }

        return (apu * sum);
    }
};
