#include <bits/stdc++.h>

int minSubarraySum(int arr[], int n, int k) 
{
    // Write your code here
    int run = 0;
    int sum = INT_MAX;

    for (int i = 0; i < k; i++)
    {
        run += arr[i];
    }

    sum = run;

    for (int i = 1; i + k - 1 < n; i++)
    {
        run += arr[i + k - 1] - arr[i - 1];
        sum = min(run, sum);
    }

    return sum;
}
