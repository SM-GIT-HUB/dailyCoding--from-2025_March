#include <bits/stdc++.h>

int minimumFlips(int a, int b, int c)
{
	// Write your code here.
	int count = 0;

	for (int bit = 30; bit >= 0; bit--)
	{
		int cset = ((c >> bit) & 1);
		int aset = ((a >> bit) & 1);
		int bset = ((b >> bit) & 1);

		if (!cset) {
			count += aset + bset;
		}
		else if (cset && !aset && !bset) {
			count++;
		}
	}

	return count;
}
