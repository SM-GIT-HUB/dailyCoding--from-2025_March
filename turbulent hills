#include <bits/stdc++.h>

int longestDangerousRange(vector<int>& arr, int n)
{   
    // Write your code here
    int len = 1;
    int idx = 0;

    while (idx < n - 1)
    {
        while (idx + 1 < n && arr[idx] == arr[idx + 1])
        {
            idx++;
        }

        if (idx >= n - 1) {
            break;
        }

        int t = 2;
        len = max(len, 2);

        int p1 = (arr[idx] < arr[idx + 1])? 0 : 1;

        int i = idx + 1;

        while (i + 1 < n && arr[i] != arr[i + 1])
        {
            int p2 = (arr[i] < arr[i + 1])? 0 : 1;

            if (p1 == p2) {
                break;
            }

            len = max(++t, len);
            p1 = p2;
            i++;
        }

        idx = i;
    }

    return len;
}
