#include <bits/stdc++.h>

void interLeaveQueue(queue<int>& q) {
    // Write your code here.
    queue<int> p;
    int n = int(q.size()) >> 1;

    while (n--)
    {
        p.push(q.front());
        q.pop();
    }

    n = int(q.size());

    while (n--)
    {
        q.push(p.front());
        q.push(q.front());

        q.pop();
        p.pop();
    }
}
