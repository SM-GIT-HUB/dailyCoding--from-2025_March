#include<bits/stdc++.h>

vector<int> printMatrix(vector<vector<int> >& mat, int m, int n)
{
    // Write your code here
    int row = 0, col = 0;

    vector<int> ans;
    vector<int> temp;
    
    for (int cn = 0; cn < m + n - 1; cn++)
    {
        temp.clear();

        for (int r = row, c = col; r >= 0 && c < n; r--, c++)
        {
            temp.push_back(mat[r][c]);
        }

        if (cn & 1) {
            reverse(temp.begin(), temp.end());
        }

        for (int x : temp) ans.push_back(x);

        if (row == m - 1) {
            col++;
        }
        else
            row++;
    }

    return ans;
}
