#include <bits/stdc++.h>

int flag = 1;
vector<int> arr[11];

void calc()
{
	flag = 0;

	for (int e = 1; e <= 10000; e++)
	{
		int c = 0;
		int elem = e;

		for (int i = 2; i * i <= elem; i++)
		{
			if (elem % i == 0)
			{
				++c;

				while (elem % i == 0)
				{
					elem = elem / i;
				}
			}
		}

		if (elem > 1) {
			++c;
		}

		if (c < 11) {
			arr[c].push_back(e);
		}
	}
}

vector<int> getNfactor(vector<vector<int> >& queries)
{
	//	Write your code here.
	if (flag) {
		calc();
	}

	vector<int> ans;

	for (auto &v : queries)
	{
		int a = v[0], b = v[1];
		int n = v[2];

		int c = upper_bound(arr[n].begin(), arr[n].end(), b) - lower_bound(arr[n].begin(), arr[n].end(), a);
		ans.push_back(c);
	}

	return ans;
}
