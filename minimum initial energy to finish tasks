class Solution {
public:
    int minimumEffort(vector<vector<int> >& tasks) {
        sort(tasks.begin(), tasks.end(), [](auto &a, auto &b) {
            return (a[1] - a[0] > b[1] - b[0]);
        });

        int sum = 0;
        int leftOver = 0;

        for (auto &x : tasks)
        {
            if (leftOver < x[1])
            {
                sum += x[1] - leftOver;
                leftOver = x[1];
            }

            leftOver -= x[0];
        }

        return sum;
    }
};
