class Solution {
public:
    bool uniformArray(vector<int>& nums1) {
        int n = int(nums1.size());

        int odd = 0;
        int even = 0;

        for (int x : nums1)
        {
            if (x & 1) ++odd;
            else ++even;
        }
        
        return (even == n || odd);
    }
};
