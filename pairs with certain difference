class Solution {
  public:
    int sumDiffPairs(vector<int>& arr, int k) {
        // code here
        int n = int(arr.size());
        sort(arr.rbegin(), arr.rend());
        
        int sum = 0;
        
        for (int i = 0; i < n - 1; i++)
        {
            if (arr[i] - arr[i + 1] < k)
            {
                sum += arr[i] + arr[i + 1];
                i++;
            }
        }
        
        return sum;
    }
};
