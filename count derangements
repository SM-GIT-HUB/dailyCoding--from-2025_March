class Solution {
  public:
    int dp[13];
    
    int mm(int n)
    {
        if (n < 4) {
            return (n - 1);
        }
        
        if (dp[n] != -1) {
            return dp[n];
        }
        
        return dp[n] = (n - 1) * (mm(n - 1) + mm(n - 2));
    }
  
    int derangeCount(int n) {
        // code here
        memset(dp, -1, sizeof(dp));
        return mm(n);
    }
};
