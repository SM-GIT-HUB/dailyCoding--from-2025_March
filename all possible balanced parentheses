#include <bits/stdc++.h>

void track(int idx, int n, int open, int close, string &str, vector<string>& ans)
{
    if (idx == (n << 1))
    {
        ans.push_back(str);
        return;
    }

    if (open < n)
    {
        str[idx] = '(';
        track(idx + 1, n, open + 1, close, str, ans);
    }

    if (close < open)
    {
        str[idx] = ')';
        track(idx + 1, n, open, close + 1, str, ans);
    }
}

vector<string> balancedParentheses(int n)
{
    // write your code here
    vector<string> ans;
    string str = string(n << 1, '.');

    track(0, n, 0, 0, str, ans);

    return ans;
}
