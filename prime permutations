#include <bits/stdc++.h>

int mod = 1e9 + 7;

using int64 = int64_t;

int isPrime(int n)
{
	for (int i = 2; i * i <= n; i++)
	{
		if (n % i == 0) return 0;
	}

	return 1;
}

int64 fact(int n)
{
	int64 fac = 1;
	for (int i = 1; i <= n; i++) fac = (fac * i) % mod;

	return fac;
}

int findPrimePermutations(int n) 
{
	// Write your code here.
	int count = 0;
	for (int i = 2; i <= n; i++) count += isPrime(i);

	return fact(count) * fact(n - count) % mod;
}
