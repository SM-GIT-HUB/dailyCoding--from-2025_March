#include <bits/stdc++.h>

int isPos(int j, vector<int>& arr)
{
    for (int x : arr)
    {
        if (x % j == 0) {
            return 0;
        }
    }

    return 1;
}

int avoidTraps(vector<int>& obstacles, int n) 
{
    // Write your code here.
    for (int j = 1; j <= 1e6 + 1; j++)
    {
        if (isPos(j, obstacles)) {
            return j;
        }
    }

    return 1e6 + 1;
}
