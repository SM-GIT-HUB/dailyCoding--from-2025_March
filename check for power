class Solution {
  public:
    bool isPower(int x, int y) {
        // code here
        int64_t p = 1;
        
        if (x == 1 && y != 1) {
            return 0;
        }
        
        while (p <= y)
        {
            if (p == y) {
                return 1;
            }
            
            p = p * x;
        }
        
        return 0;
    }
};
