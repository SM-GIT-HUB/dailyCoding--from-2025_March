class Solution {
  public:
    int dfs(Node* root)
    {
        if (!root) {
            return 0;
        }
        
        int left = dfs(root->left);
        int right = dfs(root->right);
        
        int org = root->data;
        root->data = left + right;
        
        return (org + left + right);
    }
  
    void toSumTree(Node *root) {
        // code here
        dfs(root);
    }
};
