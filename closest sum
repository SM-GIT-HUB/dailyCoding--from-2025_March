#include <bits/stdc++.h>

int closest3Sum(vector<int>& arr, int n, int target)
{
    // Write your code here
    int sum = 1e8;
    sort(arr.begin(), arr.end());

    for (int i = 0; i < n - 2; i++)
    {
        int j = i + 1;
        int k = n - 1;

        while (j < k)
        {
            int curr = arr[i] + arr[j] + arr[k];

            if (curr == target) {
                return curr;
            }

            if (abs(curr - target) < abs(sum - target) || (abs(curr - target) == abs(sum - target) && curr < sum)) {
                sum = curr;
            }

            if (curr < target) {
                j++;
            }
            else
                k--;
        }
    }

    return sum;
}
