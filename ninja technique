#include <bits/stdc++.h>

using int64 = int64_t;

bool ninjaTechnique(string str)
{
	//write your code here
    int m = int(str.size());

    for (int i = 0; i < m; i++)
    {
        if (str[i] == '0') {
            continue;
        }
        
        int64 x = 0;

        for (int j = i; j - i + 1 < 10 && j < m; j++)
        {
            x = x * 10 + (str[j] - '0');

            double d = (sqrt(4 * x + 1) - 1) / double(2);
            int64 n = int(d);

            if (n * (n + 1) == x) {
                return 1;
            }
        }
    }

    return 0;
}
