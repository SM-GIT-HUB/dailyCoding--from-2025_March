/************************************************************

    Following is the TreeNode class structure

    template <typename T>
    class TreeNode {
       public:
        T val;
        TreeNode<T> *left;
        TreeNode<T> *right;

        TreeNode(T val) {
            this->val = val;
            left = NULL;
            right = NULL;
        }
    };

************************************************************/
using Node = TreeNode<int>;

void dfs(Node* root, int &found, int m, int &succ)
{
	if (!root || succ != -1) {
		return;
	}

	dfs(root->left, found, m, succ);

	if (succ != -1) {
		return;
	}

	dfs(root->right, found, m, succ);

	if (succ != -1) {
		return;
	}

	if (root->val == m) {
		found = 1;
	}
	else if (found) {
		succ = root->val;
	}
}

