#include <bits/stdc++.h>

string nums[] = {
    "2", "22", "222", "3", "33", "333", "4", "44", "444", "5",
    "55", "555", "6", "66", "666", "7", "77", "777", "7777", "8", "88", "888",
    "9", "99", "999", "9999"
};

string convertSentence(string s, int n){
	// Write your code here.
    string str;

    for (char ch : s)
    {
        str += nums[ch - 'a'];
    }

    return str;
}
