class Solution {
public:
    bool canBeEqual(string s1, string s2) {
        int odd[26] = {0};
        int even[26] = {0};

        for (int i = 0; i < 4; i++)
        {
            if (i & 1)
            {
                odd[s1[i] - 'a']++;
                odd[s2[i] - 'a']--;
            }
            else
            {
                even[s1[i] - 'a']++;
                even[s2[i] - 'a']--;
            }
        }

        for (int i = 0; i < 26; i++)
        {
            if (odd[i] || even[i]) {
                return 0;
            }
        }

        return 1;
    }
};
