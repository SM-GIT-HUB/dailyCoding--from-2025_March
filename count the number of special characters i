class Solution {
public:
    int numberOfSpecialChars(string word) {
        bitset<26> mapp1;
        bitset<26> mapp2;

        for (char ch : word)
        {
            if (ch < 'a') {
                mapp2[ch - 'A'] = 1;
            }
            else
                mapp1[ch - 'a'] = 1;
        }

        int count = 0;

        for (int i = 0; i < 26; i++)
        {
            count += (mapp1[i] && mapp2[i]);
        }

        return count;
    }
};
