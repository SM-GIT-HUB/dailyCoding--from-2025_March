#include <bits/stdc++.h> 
/**********************************************************
    Following is the Binary Tree Node class structure

    template <typename T>
    class BinaryTreeNode {
    public :
	    T data;
	    BinaryTreeNode<T> *left;
	    BinaryTreeNode<T> *right;

	    BinaryTreeNode(T data) {
	            this -> data = data;
	            left = NULL;
	            right = NULL;
	    }
    };

***********************************************************/

using Node = BinaryTreeNode<int>;

void dfs(int r, int lvl, Node* root, int &deep, Node* &ans)
{
	if (!root) {
		return;
	}

	if (!root->left && !root->right)
	{
		if (r && (lvl > deep || lvl == deep))
		{
			ans = root;
			deep = lvl;
		}

		return;
	}

	dfs(0, lvl + 1, root->left, deep, ans);
	dfs(1, lvl + 1, root->right, deep, ans);
}

BinaryTreeNode<int>* deepestRightLeaf(BinaryTreeNode<int>* root) {
    // Write your code here.
	int deep = 0;
	Node* ans = nullptr;

	dfs(0, 0, root, deep, ans);

	return ans;
}
