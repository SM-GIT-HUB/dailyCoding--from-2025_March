class Solution {
public:
    int findMin(vector<int>& arr) {
        int n = int(arr.size());
        int start = 0, end = n - 1;

        if (arr[0] < arr[end]) {
            return arr[0];
        }

        while (start < end)
        {
            int mid = ((start + end) >> 1);

            if (arr[0] <= arr[mid]) {
                start = mid + 1;
            }
            else
                end = mid;
        }
        
        return arr[end];
    }
};
