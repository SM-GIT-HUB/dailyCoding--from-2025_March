    vector<int> st;
    vector<int> ans(n);

    for (int i = 0; i < n; i++)
    {
        if (!st.empty() && price[st.back()] <= price[i]) {
            st.pop_back();
        }

        if (!st.empty()) {
            cout << st.back() << endl;
        }

        ans[i] = st.empty()? i + 1 : i - st.back();
