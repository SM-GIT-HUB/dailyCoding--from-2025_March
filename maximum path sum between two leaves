#include <bits/stdc++.h> 
/************************************************************

    Following is the Tree node structure
	
	template <typename T>
    class TreeNode 
    {
        public : 
        T val;
        TreeNode<T> *left;
        TreeNode<T> *right;

        TreeNode(T val) 
        {
            this -> val = val;
            left = NULL;
            right = NULL;
        }
    };

************************************************************/

using Node = TreeNode<int>;

long long dfs(Node* root, long long &sum)
{
    if (!root) {
        return -1;
    }

    if (!root->left && !root->right) {
        return root->val;
    }

    long long left = dfs(root->left, sum);
    long long right = dfs(root->right, sum);

    if (left > -1 && right > -1) {
        sum = max(sum, left + right + root->val);
    }

    return root->val + max(left, right);
}

long long int findMaxSumPath(TreeNode<int> *root)
{
    long long sum = -1;
    dfs(root, sum);

    return sum;
}
