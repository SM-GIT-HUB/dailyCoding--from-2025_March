#include <bits/stdc++.h>

vector<string> arrangeAuthors(vector<vector<string> >& s)
{
    // Write your code here.
    vector<string> ans;

    for (int i = 0; i < int(s.size()); i++)
    {
        vector<string>& curr = s[i];

        ans.push_back(to_string(i + 1) + ". " + curr[0]);

        int idx = 1;

        for (int j = 1; j < int(curr.size()); j++)
        {
            ans.push_back(string(1, 'A' + j - 1) + ". " + curr[idx++]);
        }
    }

    return ans;
}
