#include <bits/stdc++.h>

int dominantNumber(int* arr, int n) 
{
	// Write your code here.
	int e1 = -1, e2 = -1;
	int c1 = 0, c2 = 0;

	for (int i = 0; i < n; i++)
	{
		int x = arr[i];

		if (x == e1) {
			++c1;
		}
		else if (x == e2) {
			++c2;
		}
		else if (c1 == 0)
		{
			e1 = x;
			c1 = 1;
		}
		else if (c2 == 0)
		{
			e2 = x;
			c2 = 1;
		}
		else
		{
			--c1;
			--c2;
		}
	}

	c1 = 0;
	c2 = 0;

	for (int i = 0; i < n; i++)
	{
		c1 += (e1 == arr[i]);
		c2 += (e2 == arr[i]);
	}

	if (c1 > n / 3) {
		return e1;
	}
	else if (c2 > n / 3) {
		return e2;
	}
	else
		return -1;
}
