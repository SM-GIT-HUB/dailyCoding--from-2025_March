#include <bits/stdc++.h> 

/****************************************************************
    Following is the class structure of the TreeNode class:
        class TreeNode
        {
          public:
	      T data;
	      TreeNode<T> *left;
	      TreeNode<T> *right;

	      TreeNode(T data)
	      {
		    this->data = data;
		    left = NULL;
		    right = NULL;
	      }
        };
*****************************************************************/

using Node = TreeNode<int>;

void dfs(Node* root, int &prev, int &diff)
{
	if (!root) {
		return;
	}

	dfs(root->left, prev, diff);

	if (prev != -1) {
		diff = min(root->data - prev, diff);
	}

	prev = root->data;

	dfs(root->right, prev, diff);
}

int ninjaGf(Node* root)
{
	// Write your code here
	int prev = -1;
	int diff = 1e9 + 1;
	dfs(root, prev, diff);

	return diff;
}
