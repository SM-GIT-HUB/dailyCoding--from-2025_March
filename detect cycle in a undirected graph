#include<bits/stdc++.h>

unordered_set<int> visited;

int dfs(int u, int par, Graph &g)
{
	visited.insert(u);

	for (int v : g.adj[u])
	{
		if (!visited.count(v))
		{
			if (dfs(v, u, g)) {
				return 1;
			}
		}
		else if (v != par) {
			return 1;
		}
	}

	return 0;
}

bool isCyclic(Graph g)
{
	visited.clear();
	
	for (int u = 0; u < g.V; u++)
	{
		if (!visited.count(u) && dfs(u, -1, g)) {
			return 1;
		}
	}

	return 0;
}
