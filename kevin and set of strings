#include <bits/stdc++.h>

int distinctStrings(vector<string>& arr, int n)
{
	//	Write your code here.
	unordered_set<string> sett;

	for (auto &s : arr)
	{
		string s1 = "";
		string s2 = "";

		for (int i = 0; i < int(s.size()); i++)
		{
			if (i & 1) {
				s2.push_back(s[i]);
			}
			else
				s1.push_back(s[i]);
		}

		sort(s1.begin(), s1.end());
		sort(s2.begin(), s2.end());

		string apu = s1 + "|" + s2;
		sett.insert(apu);
	}

	return int(sett.size());
}
