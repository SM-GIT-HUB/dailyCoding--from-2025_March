#include <bits/stdc++.h>

int dist[101][101];

string str = "URDL";
int dirs[4][2] = {{-1, 0}, {0, 1}, {1, 0}, {0, -1}};

int minDirectionChanges(vector<vector<char> >& g, int m, int n)
{
    // Write your code here
    deque<pair<int, int> > dq;
    for (int i = 0; i < m; i++) fill(dist[i], dist[i] + n, 1e8);

    dist[0][0] = 0;
    dq.push_front({0, 0});

    while (!dq.empty())
    {
        auto [x, y] = dq.front();
        dq.pop_front();

        for (int i = 0; i < 4; i++)
        {
            int c = (g[x][y] != str[i]);

            int dx = x + dirs[i][0];
            int dy = y + dirs[i][1];

            if (dx < 0 || dx == m || dy < 0 || dy == n) {
                continue;
            }

            if (dist[x][y] + c >= dist[dx][dy]) {
                continue;
            }

            dist[dx][dy] = dist[x][y] + c;

            if (c == 0) {
                dq.push_front({dx, dy});
            }
            else
                dq.push_back({dx, dy});
        }
    }

    return dist[m - 1][n - 1];
}
