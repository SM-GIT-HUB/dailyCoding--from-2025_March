class Solution {
  public:
    bool canSplit(vector<int>& arr) {
        // code here
        int64_t sum1 = 0;
        int64_t sum2 = accumulate(arr.begin(), arr.end(), 0LL);
        
        for (int x : arr)
        {
            sum1 += x;
            sum2 -= x;
            
            if (sum1 == sum2) {
                return 1;
            }
            else if (sum1 > sum2) {
                return 0;
            }
        }
        
        return 0;
    }
};
