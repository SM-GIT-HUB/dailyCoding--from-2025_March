#include <bits/stdc++.h>

vector<vector<int> > numberPattern(int n) {

  // Write your code here
  int curr = 0;
  vector<vector<int> > arr(n, vector<int>(n, -1));

  for (int i = 0; i < n; i++)
  {
    int idx = n - i - 1;

    for (int j = idx; j < n; j++)
    {
      arr[i][j] = curr + 1;
      curr = (curr + 1) % 9;
    }
  }

  return arr;
}
