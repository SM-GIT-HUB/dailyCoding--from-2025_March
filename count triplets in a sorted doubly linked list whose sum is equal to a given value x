#include <bits/stdc++.h> 
/***********************************************

    Following is the class structure of the Node class:

    class DLLNode
    {
        public:
        int data;
        DLLNode *next;
        DLLNode *prev;
    };

***********************************************/

using Node = DLLNode;

int countTriplets(DLLNode* head, int x)
{
    // WRITE YOUR CODE HERE
	Node* last = head;

	while (last->next)
	{
		last = last->next;
	}

	int count = 0;

	for (Node* curr = head; curr && curr->next != last; curr = curr->next)
	{
		Node* start = curr->next;
		Node* end = last;

		while (start && end && start->data < end->data)
		{
			int sum = curr->data + start->data + end->data;

			if (sum == x)
			{
				++count;
				start = start->next;
				end = end->prev;
			}
			else if (x < sum) {
				end = end->prev;
			}
			else
				start = start->next;
		}
	}

	return count;
}  
