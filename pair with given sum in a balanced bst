#include <bits/stdc++.h> 
/***********************************************
	The structure of Binary tree is given below: 
	
	template <typename T>
	class BinaryTreeNode {
	public:
		T data;
		BinaryTreeNode<T>* left;
		BinaryTreeNode<T>* right;

		BinaryTreeNode(T data) {
			this->data = data;
			left = NULL;
			right = NULL;
		}
	};
***********************************************/

using Node = BinaryTreeNode<int>;

void dfs(Node* root, vector<int>& arr)
{
    if (!root) {
        return;
    }

    dfs(root->left, arr);
    arr.push_back(root->data);
    dfs(root->right, arr);
}

bool findTargetPair(BinaryTreeNode<int>* root, int target)
{
	// Write your code here.
    vector<int> arr;
    dfs(root, arr);

    int start = 0, end = int(arr.size()) - 1;

    while (start < end)
    {
        int sum = arr[start] + arr[end];

        if (sum == target) {
            return 1;
        }
        else if (sum < target) {
            start++;
        }
        else
            end--;
    }

    return 0;
}
