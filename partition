#include <bits/stdc++.h> 
/****************************************************************

    Following is the class structure of the Node class:

       class Node
        {
        public:
            int data;
            Node *next;
            Node(int data)
            {
               this->data = data;
              this->next = NULL;
            }
        };

*****************************************************************/

Node* findPartiton(Node* head, int x)
{
	// Write your code here
    Node* h1 = new Node(-1);
    Node* h2 = new Node(-1);

    Node* t1 = h1;
    Node* t2 = h2;
    Node* temp = head;

    while (temp)
    {
        if (temp->data < x)
        {
            t1->next = temp;
            t1 = t1->next;
        }
        else
        {
            t2->next = temp;
            t2 = t2->next;
        }

        temp = temp->next;
    }

    t1->next = h2->next;
    t2->next = nullptr;

    return h1->next;
}
