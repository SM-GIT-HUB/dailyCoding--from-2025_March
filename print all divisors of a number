int* printDivisors(int n, int &size){
// Write your code here
    vector<int> arr;
    
    for (int i = 1; i <= n; i++)
    {
        if (n % i == 0) {
            arr.push_back(i);
        }
    }

    size = int(arr.size());

    int *p = new int[size];

    for (int i = 0; i < size; i++)
    {
        p[i] = arr[i];
    }

    return p;
}
