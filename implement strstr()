#include <bits/stdc++.h>

using uint64 = uint64_t;

uint64 power(uint64 n, uint64 m)
{
	uint64 p = 1;

	while (m)
	{
		if (m & 1) {
			p = p * n;
		}

		n = n * n;
		m = m >> 1;
	}

	return p;
}

int findIndexOf(string a, string b){
	//Write your code here
	int m = int(a.size());
	int n = int(b.size());

	if (m > n) {
		return -1;
	}

	uint64 base = 1000003;
	uint64 p = power(base, m - 1);

	uint64 ha = 0;
	uint64 hb = 0;

	for (int i = 0; i < m; i++)
	{
		ha = ha * base + a[i];
		hb = hb * base + b[i];
	}

	if (ha == hb) {
		return 0;
	}

	for (int i = 1; i + m - 1 < n; i++)
	{
		hb = (hb - p * b[i - 1]) * base + b[i + m - 1];

		if (ha == hb) {
			return i;
		}
	}

	return -1;
}
